# ================== BACKEND CONFIGURATION ==================

# Base de données (fournie par Heroku)
# DATABASE_URL=postgresql://user:pass@host:5432/dbname  # AUTO par Heroku

# Environnement
ENVIRONMENT=production
DEBUG=False

# Sécurité
SECRET_KEY=your-super-secret-key-change-this-in-heroku-config

# CORS - Adapter avec vos domaines
CORS_ORIGINS=https://frontend.herokuapp.com,https://yourdomain.com

# ================== BAMBOOPAY CONFIGURATION ==================
BAMBOOPAY_MERCHANT_ID=your-merchant-id
BAMBOOPAY_MERCHANT_SECRET=your-merchant-secret
BAMBOOPAY_MERCHANT_USERNAME=your-merchant-username
BAMBOOPAY_DEBUG=false

# ================== EMAIL CONFIGURATION ==================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=your-email@gmail.com

# ================== FRONTEND CONFIGURATION ==================
# Pour les variables d'environnement Angular
API_BASE_URL=https://backend.herokuapp.com/api
KEYCLOAK_URL=https://your-keycloak-server.com
KEYCLOAK_REALM=taxe
KEYCLOAK_CLIENT_ID=taxe-frontend
