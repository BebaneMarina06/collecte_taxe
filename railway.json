{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE"
  },
  "deploy": {
    "restartPolicyMaxRetries": 5
  },
  "environmentVariables": {
    "ENVIRONMENT": "production",
    "DEBUG": "False",
    "PYTHONUNBUFFERED": "1",
    "PYTHONDONTWRITEBYTECODE": "1"
  },
  "plugins": [
    {
      "source": "https://github.com/railwayapp/plugins/tree/main/packages/postgresql"
    }
  ]
}
